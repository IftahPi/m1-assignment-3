# Copy this file to ".env" and fill in your Nebius Token Factory API key.
# .env is gitignored and must never be committed.

NEBIUS_API_KEY=your-nebius-api-key-here

# Optional overrides (defaults shown):
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
ROUTER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
GENERATOR_MODEL=meta-llama/Llama-3.3-70B-Instruct
